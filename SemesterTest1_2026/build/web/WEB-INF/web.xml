<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>StartSessionServlet</servlet-name>
        <servlet-class>za.ac.tut.web.StartSessionServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MessageAnalyzerServlet</servlet-name>
        <servlet-class>za.ac.tut.web.MessageAnalyzerServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EndSessionServlet</servlet-name>
        <servlet-class>za.ac.tut.web.EndSessionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StartSessionServlet</servlet-name>
        <url-pattern>/StartSessionServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MessageAnalyzerServlet</servlet-name>
        <url-pattern>/MessageAnalyzerServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EndSessionServlet</servlet-name>
        <url-pattern>/EndSessionServlet.do</url-pattern>
    </servlet-mapping>
    <context-param>
        <param-name>computer</param-name>
        <param-value>Siri</param-value>
    </context-param>
    <error-page>
        <error-code>404</error-code>
        <location>/file_not_found_error_page.jsp</location>
    </error-page>
    <error-page>
        <exception-type>za.ac.tut.model.InvalidMessageException</exception-type>
        <location>/invalid_message_error_page.jsp</location>
    </error-page>
    <error-page>
        <exception-type>za.ac.tut.model.EmptyDataException</exception-type>
        <location>/empty_data_error_page.jsp</location>
    </error-page>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
